# 서버 접속 포트 (개발 `npm run dev`, exe 옆 `.env`, `npm run preview` 공통)
PORT=3005

# 바인딩 주소 (0.0.0.0 = 외부·LAN 접속 허용, exe 기본 localhost)
# HOSTNAME=0.0.0.0

# Vite dev 전용 — 허용 Host (쉼표 구분, * = 모두 허용). exe 빌드에는 포함되지 않음.
# ALLOWED_HOSTS=*

# 빌드 시점 설정 — exe 실행 시 변경 불가. 홈 버튼 URL (주석 처리 시 앱 첫 화면)
# VITE_HOME_URL=https://example.com
